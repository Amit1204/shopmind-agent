# ── LLM ───────────────────────────────────────────────────────────────────────
# Option 1: Groq (free, recommended — sign up at console.groq.com)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-70b-versatile

# Option 2: Local Mistral via Ollama (requires GPU + 4.5 GB disk)
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL_NAME=mistral:7b-instruct-q4_0
USE_LOCAL_LLM=false

# Option 3: OpenAI API (fallback)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Observability ─────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=shopmind-agent

MLFLOW_TRACKING_URI=http://localhost:5000

# ── Vector DB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./outputs/chroma_db
FAISS_INDEX_PATH=./outputs/faiss_index

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
